# DeepSeek API (deepseek-chat = 最新模型, 目前指向 DeepSeek-V4-pro)
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
OPENAI_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=career_platform

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
REDIS_RATE_LIMIT=60

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_JOBS=job_descriptions
CHROMA_COLLECTION_LEARNING=learning_resources

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Harness
AGENT_MAX_RETRIES=3
AGENT_TIMEOUT_SECONDS=300
AGENT_ASYNC_WORKERS=4

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=16
